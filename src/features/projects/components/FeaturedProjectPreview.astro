---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { buttonVariants } from '@/components/ui/button';
import { ArrowRight } from 'lucide-react';
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { LanguageCode } from '@/i18n/ui';
import type { TechnologyDetail } from '../type';

export type Props = {
  lang: LanguageCode;
  slug: string;
  title: string;
  description?: string;
  imageUrl?: ImageMetadata;
  imageAltText: string;
  ctaText: string;
  technologiesUsed?: Array<TechnologyDetail>;
};

const { lang, slug, title, description, imageUrl, imageAltText, ctaText, technologiesUsed = [] } = Astro.props;
const projectUrl = getRelativeLocaleUrl(lang, `/projects/${slug}`);
---

<a
  href={projectUrl}
  class="group relative flex flex-col w-full rounded-xl overflow-hidden shadow-md focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background border border-border transition-transform duration-300 hover:scale-[1.02] bg-card"
>
  {/* Image */}
  <div class="relative w-full h-56 overflow-hidden">
    {
      imageUrl ? (
        <Image
          src={imageUrl}
          alt={imageAltText}
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 ease-in-out group-hover:scale-105"
          widths={[400, 800, 1200]}
          sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
          quality="mid"
        />
      ) : (
        <div class="absolute inset-0 w-full h-full bg-muted flex items-center justify-center">
          <p class="text-muted-foreground text-sm">{imageAltText || 'Imagen no disponible'}</p>
        </div>
      )
    }
    <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
  </div>

  {/* Content */}
  <div class="flex flex-col flex-1 p-5">
    <h3 class="text-lg font-semibold text-foreground mb-2 group-hover:text-primary transition-colors">
      {title}
    </h3>

    {description && (
      <p class="text-sm text-muted-foreground line-clamp-2 mb-4 flex-1">
        {description}
      </p>
    )}

    {/* Technologies */}
    {technologiesUsed.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mb-4">
        {technologiesUsed.slice(0, 4).map((tech) => (
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-primary/10 text-primary border border-primary/20">
            {tech.name}
          </span>
        ))}
      </div>
    )}

    {/* CTA */}
    <div class="flex items-center text-sm font-medium text-primary gap-1 mt-auto">
      {ctaText}
      <ArrowRight className="size-3.5 transition-transform duration-200 group-hover:translate-x-1" />
    </div>
  </div>
</a>
